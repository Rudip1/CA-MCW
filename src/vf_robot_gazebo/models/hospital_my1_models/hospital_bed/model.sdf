    <link name="leg_br"><pose>-0.9 -0.38 0.22 0 0 0</pose>
      <collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.45</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.45</length></cylinder></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material></visual>
    </link>
  </model>
