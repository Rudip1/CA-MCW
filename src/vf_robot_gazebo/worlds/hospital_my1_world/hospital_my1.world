<?xml version="1.0"?>
<!--
  hospital.world — Gazebo 11 hospital simulation
  ================================================
  Building origin: (0,0,0) at center of floor plan
  Room coordinates match hospital_building model.sdf

  ROOM CENTERS (approximate, for equipment placement):
    OR-1:        x=-14, y=11.7
    OR-2:        x=-4.7,y=11.7
    OR-3:        x= 2.3,y=11.7
    Endoscopy:   x= 10.5,y=11.7
    Equipment Storage: x=18.5,y=11.7
    Anesthesia WR: x=-17.5,y=16.7
    Decontam:    x=-10.5,y=16.7
    Prep/Pack:   x=-4.3, y=16.7
    Sterile Stor:x= 3.7, y=16.7
    Gas Storage: x= 9.0, y=16.7
    Mechanical:  x=14.0, y=16.7
    ─ Mid zone ─
    Male Locker: x=-16.0,y=4.0
    Female Locker:x=-10.0,y=4.0
    Pre-op Hold: x= 2.0, y=5.0
    PACU:        x= 10.5,y=5.0
    Primary Rec: x= 17.0,y=3.0
    Pediatric:   x= 12.5,y=2.0
    ─ South zone ─
    Conference:  x=-14.5,y=-3.5
    Bulk Storage:x=-7.5, y=-2.5
    Dressing Rm: x=-2.0, y=-5.5
    Admitting:   x=-6.5, y=-6.0
    Waiting:     x= 5.0, y=-8.0
    Nurse Station:x=9.5, y=-2.0
    Med Prep:    x=13.5, y=-2.0
    Sec Recovery:x=13.5, y=-13.0
    Stretcher St:x=20.0, y=-13.0
    Reception:   x=-1.0, y=-12.0
    Records:     x=-14.0,y=-12.0
    Business Off:x=-6.5, y=-15.5
    Dir Nurses:  x=-14.5,y=-16.5
    Office:      x=-17.5,y=-9.0
-->
<sdf version="1.6">
  <world name="hospital">

    <!-- ============================================================
         PHYSICS & ENVIRONMENT
         ============================================================ -->
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <gravity>0 0 -9.8</gravity>

    <!-- Ambient light - hospital fluorescent feel -->
    <scene>
      <ambient>0.6 0.6 0.65 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- Sun light -->
    <light name="sun" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>0.7 0.7 0.7 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>0.1 0.1 -0.9</direction>
    </light>

    <!-- Overhead fluorescent lights per zone -->
    <light name="light_or_zone" type="point">
      <pose>-4.5 11.7 2.9 0 0 0</pose>
      <diffuse>0.9 0.9 0.95 1</diffuse><specular>0.3 0.3 0.3 1</specular>
      <attenuation><range>20</range><constant>0.4</constant><linear>0.05</linear><quadratic>0.001</quadratic></attenuation>
    </light>
    <light name="light_mid_zone" type="point">
      <pose>2.0 5.0 2.9 0 0 0</pose>
      <diffuse>0.85 0.85 0.9 1</diffuse><specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>22</range><constant>0.4</constant><linear>0.05</linear><quadratic>0.001</quadratic></attenuation>
    </light>
    <light name="light_waiting" type="point">
      <pose>5.0 -8.0 2.9 0 0 0</pose>
      <diffuse>0.8 0.8 0.85 1</diffuse><specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>20</range><constant>0.4</constant><linear>0.05</linear><quadratic>0.001</quadratic></attenuation>
    </light>
    <light name="light_admin" type="point">
      <pose>-7.0 -13.0 2.9 0 0 0</pose>
      <diffuse>0.8 0.8 0.85 1</diffuse><specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>18</range><constant>0.4</constant><linear>0.05</linear><quadratic>0.001</quadratic></attenuation>
    </light>
    <light name="light_recovery" type="point">
      <pose>14.0 -10.0 2.9 0 0 0</pose>
      <diffuse>0.8 0.8 0.85 1</diffuse><specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>14</range><constant>0.4</constant><linear>0.05</linear><quadratic>0.001</quadratic></attenuation>
    </light>

    <!-- ============================================================
         GROUND PLANE (outside building)
         ============================================================ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.4 0.5 0.4 1</ambient><diffuse>0.4 0.5 0.4 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         HOSPITAL BUILDING STRUCTURE
         ============================================================ -->
    <include>
      <uri>model://hospital_building</uri>
      <name>hospital_building</name>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- ============================================================
         OPERATING ROOM 1  (x=-14, y=11.7)
         Equipment: OR table, anesthesia machine, surgical light,
                    instrument table, patient monitor, supply cart
         ============================================================ -->
    <include>
      <uri>model://operating_table</uri>
      <name>or1_table</name>
      <pose>-14.0 11.7 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://anesthesia_machine</uri>
      <name>or1_anesthesia</name>
      <pose>-11.5 13.0 0 0 0 1.5708</pose>
    </include>
    <include>
      <uri>model://surgical_light</uri>
      <name>or1_light</name>
      <pose>-14.0 11.7 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://instrument_table</uri>
      <name>or1_instruments</name>
      <pose>-12.5 10.5 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://patient_monitor</uri>
      <name>or1_monitor</name>
      <pose>-16.0 12.5 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://supply_cart</uri>
      <name>or1_supply</name>
      <pose>-15.5 10.3 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://iv_stand</uri>
      <name>or1_iv</name>
      <pose>-12.0 12.8 0 0 0 0</pose>
    </include>

    <!-- ============================================================
         OPERATING ROOM 2  (x=-4.7, y=11.7)
         ============================================================ -->
    <include>
      <uri>model://operating_table</uri>
      <name>or2_table</name>
      <pose>-4.7 11.7 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://anesthesia_machine</uri>
      <name>or2_anesthesia</name>
      <pose>-2.2 13.0 0 0 0 1.5708</pose>
    </include>
    <include>
      <uri>model://surgical_light</uri>
      <name>or2_light</name>
      <pose>-4.7 11.7 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://instrument_table</uri>
      <name>or2_instruments</name>
      <pose>-3.2 10.5 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://patient_monitor</uri>
      <name>or2_monitor</name>
      <pose>-6.7 12.5 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://supply_cart</uri>
      <name>or2_supply</name>
      <pose>-6.2 10.3 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://iv_stand</uri>
      <name>or2_iv</name>
      <pose>-2.7 12.8 0 0 0 0</pose>
    </include>

    <!-- ============================================================
