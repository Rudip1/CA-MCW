    <include>
      <uri>model://stretcher</uri>
      <name>equip_stretcher1</name>
      <pose>17.5 12.5 0 0 0 1.5708</pose>
    </include>
    <include>
      <uri>model://stretcher</uri>
      <name>equip_stretcher2</name>
